# Copy this file to .env and fill in your keys
# Never commit .env to git

# RentCast — https://app.rentcast.io/app/api-keys
VITE_RENTCAST_API_KEY=your_rentcast_key_here

# Google Places — https://console.cloud.google.com (enable "Places API")
VITE_GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
